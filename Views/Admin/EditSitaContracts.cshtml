@model IEnumerable<SitaCptTicketApp.Models.SitaContract>

@{
    ViewData["Title"] = "Edit Sita Contracts";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SitaCptTicketApp</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@fortawesome/fontawesome-free@6.4.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>
<main>
    <div class="main-container">
        <div class="dashboard-content">
            <h1 class="page-title">Edit Sita Contracts</h1>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
            }

            <div class="card">
                <h2 class="card-title">Contracts Table</h2>
                <div class="card-actions">
                    <a asp-action="EditSitaContract" class="btn btn-sita">Add New Contract</a>
                </div>
                @if (Model != null && Model.Any())
                {
                    <table class="contracts-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Company Name</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var contract in Model.OrderBy(c => c.CompanyName))
                            {
                                <tr>
                                    <td>@contract.Id</td>
                                    <td>@contract.CompanyName</td>
                                    <td>
                                        <a asp-action="EditSitaContract" asp-route-id="@contract.Id" class="btn btn-sita btn-small">Edit</a>
                                        <form asp-action="DeleteSitaContract" method="post" style="display: inline;">
                                            <input type="hidden" name="id" value="@contract.Id" />
                                            <button type="submit" class="btn btn-danger btn-small" onclick="return confirm('Are you sure you want to delete this contract?');">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="no-data">No contracts available.</p>
                }
            </div>
        </div>
    </div>
</main>

<style>
    :root {
        --primary: #003087;
        --accent: #0058cc;
        --secondary: #6c757d;
        --danger: #dc3545;
        --text: #333333;
        --text-secondary: #666666;
        --card-bg: #ffffff;
        --background: #f5f7fa;
    }

    body {
        font-family: 'Roboto', sans-serif;
        background: var(--background);
        margin: 0;
        padding: 0;
    }

    .main-container {
        display: flex;
        justify-content: center;
        width: 100%;
        margin: 0 0 40px;
        box-sizing: border-box;
        padding: 20px;
    }

    .dashboard-content {
        width: 100%;
        max-width: 1200px;
        padding: 20px 15px 0;
    }

    .page-title {
        font-size: 32px;
        color: var(--primary);
        margin-bottom: 30px;
        text-align: center;
        font-weight: 700;
    }

    .card {
        background: var(--card-bg);
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 30px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05);
    }

    .card-title {
        font-size: 24px;
        color: var(--primary);
        margin-bottom: 10px;
        text-align: center;
        font-weight: 700;
    }

    .card-actions {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 15px;
    }

    .contracts-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
    }

    .contracts-table th,
    .contracts-table td {
        padding: 10px;
        text-align: left;
        border-bottom: 1px solid #e0e7f0;
        font-size: 14px;
    }

    .contracts-table th {
        background: #e6f0fa;
        color: var(--primary);
        font-weight: 600;
    }

    .contracts-table td {
        color: var(--text);
    }

    .btn {
        padding: 8px 12px;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        transition: background 0.2s ease;
    }

    .btn-sita {
        background: var(--accent);
        color: #fff;
    }

    .btn-sita:hover {
        background: var(--primary);
    }

    .btn-danger {
        background: var(--danger);
        color: #fff;
    }

    .btn-danger:hover {
        background: #c82333;
    }

    .btn-small {
        padding: 5px 10px;
        font-size: 12px;
    }

    .alert {
        font-size: 14px;
        padding: 10px;
        border-radius: 5px;
        margin-bottom: 15px;
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
    }

    .alert-danger {
        background: #f8d7da;
        color: #721c24;
    }

    .no-data {
        font-size: 14px;
        color: var(--text-secondary);
        text-align: center;
        margin: 20px 0;
    }

    @@media (max-width: 768px) {
        .page-title {
            font-size: 28px;
        }

        .card {
            padding: 15px;
        }

        .contracts-table th,
        .contracts-table td {
            font-size: 12px;
            padding: 8px;
        }

        .btn {
            padding: 6px 10px;
            font-size: 12px;
        }
    }
</style>
</body>
</html>